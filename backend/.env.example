# TORDIT backend — config ของ LLM (คัดลอกเป็น .env แล้วแก้ค่า)
# ดูรายละเอียดที่ app/llm.py

# โหมดการตรวจ: mock = คืน findings ตัวอย่าง (ไม่ต้องมี key) | live = ยิงโมเดลจริง
LLM_MODE=live

# provider + model (สลับ provider ได้ด้วยการแก้ 2 บรรทัดนี้ + ตั้ง API key)
# provider อื่นต้องลง integration package เพิ่ม เช่น `uv pip install -e ".[llm]"`

# --- Google AI Studio (Gemini) — เฟส few-shot ปัจจุบัน ---
LLM_PROVIDER=google_genai
LLM_MODEL=gemini-2.5-flash
# ทางเลือกคุณภาพสูงสุด: LLM_MODEL=gemini-2.5-pro
# (ยืนยัน model id ที่ใช้ได้จาก Google AI Studio อีกที — id อาจเปลี่ยนตามรุ่นที่เปิดให้ใช้)
GOOGLE_API_KEY=

# --- ทางเลือกอื่น (สลับได้ภายหลัง) ---
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=

# --- Debug ---
# เปิด endpoint POST /api/v1/debug/extract (คืน raw text ของเอกสาร)
# ปิดเป็น default เพื่อความปลอดภัย ตั้งเป็น 1 เฉพาะตอน dev
# ENABLE_DEBUG_ENDPOINTS=1

# --- Job store (ผลตรวจในหน่วยความจำ) ---
# JOB_TTL_SECONDS=3600   # ผลตรวจอยู่ได้กี่วินาทีก่อนถูกกวาดทิ้ง (default 1 ชม.)
# JOB_MAX_ENTRIES=1000   # เก็บได้สูงสุดกี่รายการ เกินกว่านี้ทิ้งตัวเก่าสุด
